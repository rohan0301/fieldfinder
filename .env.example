# FieldFinder Environment Configuration
# Copy this file to .env.local and fill in your values

# Google Maps API Key
# Required to display the interactive map
# Get your key: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: Forge proxy API key (fallback if Google Maps key not provided)
# Leave empty unless you're running a Forge proxy server
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev
